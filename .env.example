# 代码项目目录
WEB_ROOT_PATH=./www
# 查看日志目录
LOG_PATH=./log
# 存储数据目录
STORE_PATH=./store
# 配置目录
CONF_PATH=./conf

# 宿主机端口(本地访问端口)
# Mysql端口
MYSQL_PORT=3306
MYSQL_PORT8=3308

# 后面改造，密码默认为空
# root 用户密码
MYSQL_ROOT_PASSWORD=a123456

# Redis 端口
REDIS_PORT=6379

# Mongodb端口
MONGODB_PORT=27017

# Nginx端口
NGINX_PORT=80

# Nacos端口
NACOS_PORT=8848

# Rabbitmq UI端口
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# Elasticsearch
ELASTICSEARCH_PORT=9200

# Kibana
KIBANA_PORT=5601

# Logstash
LOGSTASH_PORT=5044
LOGSTASH_UI_PORT=9600